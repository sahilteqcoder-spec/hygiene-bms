# Supabase — copy to .env.local and fill in from your Supabase project (Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. NEVER expose to the browser. Used by admin/seed/server routes that bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used for absolute URLs in emails / PDF links
NEXT_PUBLIC_SITE_URL=http://localhost:3000
